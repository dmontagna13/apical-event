# Apical-Event environment variables
# API keys (optional if configured in providers.yaml)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
NSCALE_API_KEY=

# Server port (host binding)
APICAL_PORT=8420
# Server host (public address for session URLs; port taken from APICAL_PORT)
APICAL_HOST=

# Data directory (host path for persisted state)
APICAL_DATA=./data
